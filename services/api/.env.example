# WaveAI API — variáveis de ambiente (exemplo).
# Copie para `.env` (NÃO commitar o .env real — coberto pelo .gitignore).
# Prefixo obrigatório: WAVEAI_API_

WAVEAI_API_APP_NAME=waveai-api
WAVEAI_API_APP_ENV=development

# Banco (o default aponta para o Postgres do docker-compose local).
WAVEAI_API_DATABASE_URL=postgresql+psycopg://waveai:waveai_dev@localhost:5432/waveai

# Argon2id (ADR-0020) — mínimos OWASP: m=19 MiB (19456 KiB), t=2, p=1.
WAVEAI_API_ARGON2_MEMORY_COST=19456
WAVEAI_API_ARGON2_TIME_COST=2
WAVEAI_API_ARGON2_PARALLELISM=1
