# WaveAI API — variáveis de ambiente (exemplo).
# Copie para `.env` (NÃO commitar o .env real — coberto pelo .gitignore).
# Prefixo obrigatório: WAVEAI_API_

WAVEAI_API_APP_NAME=waveai-api
WAVEAI_API_APP_ENV=development

# Banco (o default aponta para o Postgres do docker-compose local).
WAVEAI_API_DATABASE_URL=postgresql+psycopg://waveai:waveai_dev@localhost:5432/waveai

# Argon2id (ADR-0020) — mínimos OWASP: m=19 MiB (19456 KiB), t=2, p=1.
WAVEAI_API_ARGON2_MEMORY_COST=19456
WAVEAI_API_ARGON2_TIME_COST=2
WAVEAI_API_ARGON2_PARALLELISM=1

# JWT (ADR-0021/0023). OBRIGATÓRIO e SEM default: a app não sobe sem isto.
# Gere o seu (NUNCA reaproveite o valor abaixo):
#   openssl rand -hex 32
WAVEAI_API_JWT_SECRET=troque-me-openssl-rand-hex-32-xxxxxxxxxxxxxxxxxxxxxxxx
WAVEAI_API_ACCESS_TOKEN_TTL_MINUTES=15
WAVEAI_API_REFRESH_TOKEN_TTL_DAYS=7

# Cookie do refresh no web. `Secure` exige HTTPS — em dev local sem TLS o
# navegador descarta o cookie, então ali (e só ali) use false.
WAVEAI_API_REFRESH_COOKIE_SECURE=true
WAVEAI_API_REFRESH_COOKIE_SAMESITE=lax

# Rate limiting do login (ADR-0023).
WAVEAI_API_LOGIN_RATE_LIMIT_ATTEMPTS=5
WAVEAI_API_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Cifragem em repouso do Result (ADR-0026). OBRIGATÓRIA, sem default.
# Gere a SUA (nunca reaproveite exemplos):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WAVEAI_API_RESULT_ENCRYPTION_KEY=troque-me-fernet-generate-key-xxxxxxxxxxxxxxxxxxx=
# GATE de produção (ADR-0026): mantenha `false` em produção até o consentimento
# no fluxo (#29). Em dev/test fica ligado, mas só com dados sintéticos.
WAVEAI_API_RESULT_PERSISTENCE_ENABLED=true
