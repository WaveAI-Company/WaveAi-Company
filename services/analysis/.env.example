# WaveAI Analysis — variáveis de ambiente (exemplo).
# Copie para `.env` (NÃO commitar o .env real — coberto pelo .gitignore).
# Prefixo obrigatório: WAVEAI_ANALYSIS_

WAVEAI_ANALYSIS_APP_NAME=waveai-analysis
WAVEAI_ANALYSIS_APP_ENV=development
# Duração (s) de cada condição no demo sintético.
WAVEAI_ANALYSIS_DEMO_SECONDS=30
