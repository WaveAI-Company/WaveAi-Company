# WaveAI — variáveis do docker-compose (exemplo).
# Copie para `infra/.env` e ajuste. O `.env` real NÃO é versionado.
#
# ATENÇÃO: os valores abaixo são de DESENVOLVIMENTO LOCAL. Em qualquer ambiente
# compartilhado, gere segredos próprios e injete-os pelo ambiente/secret manager.

POSTGRES_USER=waveai
POSTGRES_PASSWORD=waveai_dev
POSTGRES_DB=waveai
POSTGRES_PORT=5432

API_PORT=8000
WAVEAI_API_APP_ENV=development

ANALYSIS_PORT=8001
WAVEAI_ANALYSIS_APP_ENV=development
